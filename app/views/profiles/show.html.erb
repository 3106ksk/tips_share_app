<div class="min-h-[calc(100vh-7rem)] flex items-center justify-center px-8" style="background-color: #f5f0e8;">
  <div class="w-full max-w-md py-16">

    <p class="text-center mb-6 tracking-widest"
       style="color: #9b7d3c; font-family: 'Georgia', serif; font-style: italic; font-size: 0.7rem; letter-spacing: 0.35em;">
      &mdash;&nbsp;Your Profile&nbsp;&mdash;
    </p>

    <h2 class="text-center mb-14 font-light"
        style="font-size: 1.6rem; color: #2c2c2c;
               font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
               letter-spacing: 0.08em;">
      プロフィール
    </h2>

    <div class="grid grid-cols-1 gap-8">

      <div>
        <p class="block text-xs tracking-widest mb-3"
           style="color: #6b6b6b; font-family: 'Hiragino Kaku Gothic ProN', sans-serif; letter-spacing: 0.15em;">
          ユーザー名
        </p>
        <p class="px-0 py-3 text-sm"
           style="border-bottom: 1px solid #c8b89a; color: #2c2c2c;
                  font-family: 'Hiragino Kaku Gothic ProN', sans-serif; font-weight: 300;">
          <%= current_user.name %>
        </p>
      </div>

      <%= link_to "プロフィールを編集する", edit_profile_path,
          class: "block w-full py-4 mt-6 text-sm tracking-widest text-center transition-opacity hover:opacity-80",
          style: "background-color: #9b7d3c; color: #f5f0e8;
                  font-family: 'Hiragino Kaku Gothic ProN', sans-serif;
                  font-weight: 500; letter-spacing: 0.15em;" %>

    </div>

  </div>
</div>
