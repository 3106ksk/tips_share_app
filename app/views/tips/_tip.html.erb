<div id="tip-id-<%= tip.id %>" class="px-8 py-8 border-b border-[#d4c9b0]" style="background-color: #ede8dc;">
  <h2 class="text-xl font-semibold mb-4" style="color: #2c2c2c;"><%= link_to tip.title, tip_path(tip) %></h2>
  <div class="mb-4">
    <span class="text-xs font-semibold uppercase tracking-widest" style="color: #9b7d3c;">課題</span>
    <p class="mt-1 text-sm" style="color: #5a5a5a; line-height: 1.75;"><%= tip.problem %></p>
  </div>
  <div class="mb-4">
    <span class="text-xs font-semibold uppercase tracking-widest" style="color: #9b7d3c;">具体的な行動</span>
  <p class="text-sm" style="color: #6b6b6b; line-height: 1.75;"><%= tip.action %></p>
  </div>
    <% if tip.reference_url.present? %>
      <%= link_to '参考URL', tip.reference_url,
            class: "text-[11px] tracking-wider text-stone-400 border border-black/15 px-2.5 py-0.5 rounded-sm hover:border-amber-700 hover:text-amber-700 transition-colors",
            target: "_blank", rel: "noopener noreferrer" %>
    <% end %>
    <!-- 投稿者（コンテンツ下部） -->
<div class="flex items-center justify-end gap-2 mt-5 pt-4 border-t border-black/10">
  <span class="text-[11px] tracking-widest text-stone-400">投稿者：</span>
  <div class="flex items-center gap-2">
    <span class="text-[11px] tracking-widest text-stone-400"><%= tip.user.name %></span>
  </div>
</div>
</div>
