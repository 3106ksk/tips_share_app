<div class="min-h-[calc(100vh-7rem)] flex items-center justify-center px-8 py-16" style="background-color: #f5f0e8;">
  <div class="w-full max-w-2xl">

    <p class="text-center mb-6 tracking-widest"
       style="color: #9b7d3c; font-family: 'Georgia', serif; font-style: italic; font-size: 0.7rem; letter-spacing: 0.35em;">
      &mdash;&nbsp;Share Your Knowledge&nbsp;&mdash;
    </p>

    <h2 class="text-center mb-14 font-light"
        style="font-size: 1.6rem; color: #2c2c2c;
               font-family: 'Hiragino Mincho ProN', 'Yu Mincho', serif;
               letter-spacing: 0.08em;">
      Tips を投稿する
    </h2>

    <%= form_with model: @tip do |form| %>
      <div class="grid grid-cols-1 gap-8">

        <div>
          <%= form.label :title, "タイトル",
              class: "block text-xs tracking-widest mb-3",
              style: "color: #6b6b6b; font-family: 'Hiragino Kaku Gothic ProN', sans-serif; letter-spacing: 0.15em;" %>
          <%= form.text_field :title,
              placeholder: "Tips のタイトルを一言で入力",
              class: "block w-full px-0 py-3 bg-transparent text-sm focus:outline-none",
              style: "border: none; border-bottom: 1px solid #c8b89a; color: #2c2c2c;
                      font-family: 'Hiragino Kaku Gothic ProN', sans-serif; font-weight: 300;
                      border-radius: 0;" %>
        </div>

        <div>
          <%= form.label :problem, "課題・問題",
              class: "block text-xs tracking-widest mb-3",
              style: "color: #6b6b6b; font-family: 'Hiragino Kaku Gothic ProN', sans-serif; letter-spacing: 0.15em;" %>
          <%= form.text_area :problem,
              placeholder: "どんな問題に直面しましたか？",
              rows: 3,
              class: "block w-full px-0 py-3 bg-transparent text-sm focus:outline-none resize-none",
              style: "border: none; border-bottom: 1px solid #c8b89a; color: #2c2c2c;
                      font-family: 'Hiragino Kaku Gothic ProN', sans-serif; font-weight: 300;
                      border-radius: 0;" %>
        </div>

        <div>
          <%= form.label :action, "行動・対処",
              class: "block text-xs tracking-widest mb-3",
              style: "color: #6b6b6b; font-family: 'Hiragino Kaku Gothic ProN', sans-serif; letter-spacing: 0.15em;" %>
          <%= form.text_area :action,
              placeholder: "どんな行動を取りましたか？",
              rows: 3,
              class: "block w-full px-0 py-3 bg-transparent text-sm focus:outline-none resize-none",
              style: "border: none; border-bottom: 1px solid #c8b89a; color: #2c2c2c;
                      font-family: 'Hiragino Kaku Gothic ProN', sans-serif; font-weight: 300;
                      border-radius: 0;" %>
        </div>

        <div>
          <%= form.label :reference_url, "参考URL（任意）",
              class: "block text-xs tracking-widest mb-3",
              style: "color: #6b6b6b; font-family: 'Hiragino Kaku Gothic ProN', sans-serif; letter-spacing: 0.15em;" %>
          <%= form.text_field :reference_url,
              placeholder: "https://example.com",
              class: "block w-full px-0 py-3 bg-transparent text-sm focus:outline-none",
              style: "border: none; border-bottom: 1px solid #c8b89a; color: #2c2c2c;
                      font-family: 'Hiragino Kaku Gothic ProN', sans-serif; font-weight: 300;
                      border-radius: 0;" %>
        </div>

        <div>
          <p class="block text-xs tracking-widest mb-5"
             style="color: #6b6b6b; font-family: 'Hiragino Kaku Gothic ProN', sans-serif; letter-spacing: 0.15em;">
            カテゴリー
          </p>
          <div class="flex flex-wrap gap-3">
            <%= form.collection_radio_buttons :category_id, Category.order(:name), :id, :name do |b| %>
              <label class="cursor-pointer">
                <%= b.radio_button class: "hidden peer" %>
                <span class="block text-xs px-4 py-2 transition-all peer-checked:bg-[#9b7d3c] peer-checked:border-[#9b7d3c] peer-checked:text-[#f5f0e8]"
                      style="border: 1px solid #c8b89a; color: #6b6b6b;
                             font-family: 'Hiragino Kaku Gothic ProN', sans-serif;
                             letter-spacing: 0.1em;">
                  <%= b.text %>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <%= form.submit "投稿する",
            class: "w-full py-4 mt-6 text-sm tracking-widest cursor-pointer transition-opacity hover:opacity-80",
            style: "background-color: #9b7d3c; color: #f5f0e8;
                    font-family: 'Hiragino Kaku Gothic ProN', sans-serif;
                    font-weight: 500; letter-spacing: 0.15em; border: none;" %>

      </div>
    <% end %>

  </div>
</div>
