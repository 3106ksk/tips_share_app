<%# ===== HERO SECTION ===== %>
<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center"
         style="background-color: #f5f0e8; padding-top: 80px;">

  <div class="text-center px-8 max-w-4xl z-10">

    <%# エディトリアルキャプション %>
    <p class="mb-14 tracking-widest"
       style="color: #9b7d3c; font-family: 'Georgia', 'Garamond', Georgia, serif; font-style: italic; font-size: 0.75rem; letter-spacing: 0.35em;">
      &mdash;&nbsp;Learning Tips Community&nbsp;&mdash;
    </p>

    <%# メインヒーロータイトル %>
    <h1 class="leading-relaxed mb-14"
        style="font-size: clamp(2.4rem, 6.5vw, 4.8rem); color: #2c2c2c;
               font-family: 'Hiragino Mincho ProN', 'Yu Mincho', 'Noto Serif JP', serif;
               font-weight: 300; letter-spacing: 0.06em; line-height: 1.7;">
      あなたの学び方、<br>誰かのヒントになる
    </h1>

    <%# CTAボタン %>
    <div class="flex justify-center gap-5">
      <%= link_to "新規登録する", new_user_path,
          class: "text-sm px-10 py-4 tracking-widest transition-opacity hover:opacity-75",
          style: "background-color: #9b7d3c; color: #f5f0e8;
                  font-family: 'Hiragino Kaku Gothic ProN', sans-serif;
                  font-weight: 500; letter-spacing: 0.12em;" %>
      <%= link_to "ログイン", login_path,
          class: "text-sm px-10 py-4 tracking-widest transition-colors hover:border-stone-500 hover:text-stone-600",
          style: "border: 1px solid #2c2c2c; color: #2c2c2c;
                  font-family: 'Hiragino Kaku Gothic ProN', sans-serif;
                  font-weight: 300; letter-spacing: 0.12em;" %>
    </div>
  </div>
</section>
